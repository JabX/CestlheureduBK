@page "/mystere/{start}"
@page "/mystere/{start}/{restaurantId}"
@using CestlheureduBK.Services

@inject GetDataService getDataService

<PageTitle>C'est l'heure du BK ! - Burger Mystère</PageTitle>

<h1>Burger Mystère</h1>

<Header Data=@headerData />

@if (data != null && headerData?.Restaurant != null)
{
    <Mystere 
        Data="@data"
        Start="@DateOnly.Parse(Start)"
        Campaigns="@campaigns"
        IsAuthenticated=@(headerData.IsAuthenticated)
        IsCurrent="@(isCurrent)"
        CodeRestaurant="@headerData.Restaurant.Id"
    />
} 

@code {
    private IList<BurgerMystereListDisplay>? data;
    private HeaderDisplay? headerData;
    private IList<BurgerMysterePeriodDisplay>? campaigns;
    private bool isCurrent;

    [Parameter]
    public required string Start { get; set; }

    [Parameter]
    public string? RestaurantId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        headerData = await getDataService.GetHeaderData(RestaurantId);

        if (headerData.Restaurant != null)
        {
            campaigns = await getDataService.GetBurgerMystereCampaigns();
            data = await getDataService.GetBurgerMystere(DateOnly.Parse(Start), headerData.Restaurant.Id);
            var current = campaigns.FirstOrDefault();
            var today = DateOnly.FromDateTime(DateTime.Now);
            isCurrent = current?.Start <= today && current?.End >= today;
        }
    }
}
